# Copy this file to .env for local development only.
# Do not put real production secrets in this file and do not commit .env files.

APP_ENV=local
APP_NAME="AE NetScope"
DEPLOYMENT_PLATFORM=local
APP_URL=http://127.0.0.1:5173
APP_WEB_DIST_DIR=

WEB_HOST=127.0.0.1
WEB_PORT=5173
VITE_API_BASE_URL=http://127.0.0.1:8000/api

API_HOST=127.0.0.1
API_PORT=8000
API_CORS_ORIGINS=http://127.0.0.1:5173

DATABASE_URL=sqlite+aiosqlite:///./var/ae_netscope.local.db
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=ae_netscope
POSTGRES_USER=ae_netscope
POSTGRES_PASSWORD=replace-with-local-postgres-password

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_RATE_LIMIT_FAIL_OPEN=true

MAX_IMPORT_JSON_BYTES=2000000
MAX_REQUEST_BODY_BYTES=1000000

SESSION_SECRET=replace-with-at-least-32-random-bytes
# Keep this independent from SESSION_SECRET so session-key rotation cannot lock out TOTP users.
MFA_ENCRYPTION_KEY=replace-with-an-independent-random-value
# Optional comma-separated previous MFA keys used during a controlled key rotation.
MFA_DECRYPTION_FALLBACK_KEYS=
INITIAL_SETUP_TOKEN=
SESSION_COOKIE_NAME=ae_netscope_session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=strict
SESSION_TTL_SECONDS=28800

SECURITY_HEADERS_ENABLED=true
SECURITY_HSTS_ENABLED=false
SECURITY_HSTS_MAX_AGE=31536000

AE_NETSCOPE_RUN_MIGRATIONS=true
AE_NETSCOPE_MIGRATION_ATTEMPTS=30
AE_NETSCOPE_MIGRATION_RETRY_SECONDS=2
AE_NETSCOPE_PRE_MIGRATION_BACKUP=true
AE_NETSCOPE_MIGRATION_BACKUP_DIR=/app/backups
AE_NETSCOPE_MIGRATION_BACKUP_RETENTION_COUNT=10
INVENTORY_BACKUP_DIR=/app/backups
INVENTORY_BACKUP_RETENTION_COUNT=10
AE_NETSCOPE_AUTO_UPDATE_ENABLED=false
AE_NETSCOPE_AUTO_UPDATE_COMMAND=

# Required to enable passkeys. Use the exact hostname and public origin.
WEBAUTHN_RP_ID=
WEBAUTHN_ORIGIN=
WEBAUTHN_RP_NAME="AE NetScope"

AUTH_RATE_LIMIT_PER_MINUTE=5
AUTH_FAILED_LOGIN_LIMIT=10
AUTH_LOCKOUT_MINUTES=15
SESSION_RECORD_RETENTION_DAYS=30
AUDIT_RETENTION_DAYS=365
