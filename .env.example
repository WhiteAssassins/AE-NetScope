# Copy this file to .env for local development only.
# Do not put real production secrets in this file and do not commit .env files.

APP_ENV=local
APP_NAME="AE NetScope"
APP_URL=http://127.0.0.1:5173

WEB_HOST=127.0.0.1
WEB_PORT=5173
VITE_API_BASE_URL=http://127.0.0.1:8000/api

API_HOST=127.0.0.1
API_PORT=8000
API_CORS_ORIGINS=http://127.0.0.1:5173

DATABASE_URL=sqlite+aiosqlite:///./var/ae_netscope.local.db
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=ae_netscope
POSTGRES_USER=ae_netscope
POSTGRES_PASSWORD=replace-with-local-postgres-password

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_RATE_LIMIT_FAIL_OPEN=true

SESSION_SECRET=replace-with-at-least-32-random-bytes
SESSION_COOKIE_NAME=ae_netscope_session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=strict
SESSION_TTL_SECONDS=28800

PASSWORD_HASH_ALGORITHM=argon2id
AUTH_RATE_LIMIT_PER_MINUTE=5
AUTH_FAILED_LOGIN_LIMIT=10
AUTH_LOCKOUT_MINUTES=15

CRYPTO_POLICY_VERSION=1
PQC_READINESS_MODE=crypto-agile
